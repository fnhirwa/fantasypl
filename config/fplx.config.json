{
  "model_type": "inference",
  "optimizer": "ilp",
  "budget": 100.0,
  "horizon": 1,
  "formation": "auto",
  "risk_aversion": 0.5,
  "feature_engineering": {
    "rolling_windows": [3, 5, 10],
    "lag_periods": [1, 2, 3],
    "ewma_alphas": [0.3, 0.5]
  },
  "signals": {
    "stats_weights": {
      "points_mean": 0.3,
      "xG_mean": 0.15,
      "xA_mean": 0.15,
      "minutes_consistency": 0.2,
      "form_trend": 0.2
    }
  },
  "inference": {
    "hmm_variance_floor": 1.0,
    "fusion_mode": "calibrated_alpha",
    "fusion_params": {
      "default_alpha": 0.7,
      "grid_step": 0.05,
      "min_history": 8
    },
    "hmm_params": {},
    "kf_params": {},
    "mvhmm_params": {
      "prior_weight": 0.85,
      "n_iter": 15,
      "lookback": 6,
      "min_history": 3
    },
    "tft_params": {
      "checkpoint": null,
      "encoder_length": 15
    },
    "news_params": {
      "classification_thresholds": {
        "unavailable_max_availability": 0.1,
        "doubtful_max_availability": 0.6,
        "rotation_min_minutes_risk": 0.5,
        "positive_min_availability": 0.85,
        "positive_max_availability": 1.0,
        "positive_max_minutes_risk": 0.1
      },
      "perturbation_map": {
        "unavailable": {
          "state_boost": {
            "0": 10.0,
            "1": 2.0
          },
          "kalman_shock": 5.0
        },
        "doubtful": {
          "state_boost": {
            "0": 3.0,
            "1": 2.0
          },
          "kalman_shock": 2.0
        },
        "rotation": {
          "state_boost": {
            "1": 2.0,
            "2": 1.5
          },
          "kalman_shock": 1.5
        },
        "positive": {
          "state_boost": {
            "3": 2.0,
            "4": 1.5
          },
          "kalman_shock": 1.0
        },
        "neutral": {
          "state_boost": {},
          "kalman_shock": 1.0
        }
      },
      "default_confidence": 0.6
    }
  }
}
